AddOptionMenu "OptionsMenu" after "os_Menu"
{
	StaticText ""
	StaticText "NashBar v0.91"
	Submenu "$OPTMNU_NASHBAR", "NashBarOptionMenu"
}

AddOptionMenu "OptionsMenuSimple" after "os_Menu"
{
	StaticText ""
	StaticText "NashBar v0.91"
	Submenu "$OPTMNU_NASHBAR", "NashBarOptionMenu"
}

OptionMenu "NashBarOptionMenu"
{
	Title "$OPTMNU_NASHBAR"
	Position -32
	Option "$OPTMNU_NASHBAR_HP_BAR", "nashbar_hpbar", "OnOff"
}
